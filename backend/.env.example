# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voicedin

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Static Premium Payment QR
PREMIUM_PAYMENT_AMOUNT=99
PREMIUM_PAYMENT_UPI_ID=your-upi-id@bank
PREMIUM_PAYMENT_PAYEE_NAME=Your Name
PREMIUM_PAYMENT_QR_URL=/premium-payment-qr.svg
PREMIUM_PAYMENT_NOTE=Send payment screenshot after scanning the QR. Premium is activated after confirmation.

# Godmode admin approval
GODMODE_ADMIN_KEY=change-this-admin-key

# Frontend URL(s) for CORS. Use comma-separated values if you need local + deployed.
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173,https://voicedin2.onrender.com,https://voicedin.lat,https://www.voicedin.lat

# Upload directory
UPLOAD_DIR=uploads

# Optional: set this if Puppeteer needs an explicit browser path
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Optional: Render/Linux browser cache used by Puppeteer
# PUPPETEER_CACHE_DIR=.cache/puppeteer
